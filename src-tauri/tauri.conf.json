{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CS2 Reactions",
  "version": "4.4.5",
  "identifier": "com.cs2reactions.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CS2 REACTIONS",
        "label": "main",
        "width": 960,
        "height": 720,
        "resizable": true,
        "minWidth": 600,
        "minHeight": 450,
        "maximizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$CACHE/**", "$DESKTOP/**", "$DOCUMENT/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["presets/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/installer.ico"
      }
    }
  }
}
